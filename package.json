{
  "name": "impeccable-flutter",
  "version": "3.1.1",
  "author": "Paul Bakaus",
  "description": "Design skills, commands, and anti-pattern detection for Flutter development",
  "keywords": [
    "flutter",
    "dart",
    "design",
    "ux",
    "skills",
    "ai",
    "anti-patterns",
    "lint",
    "accessibility",
    "ci-cd"
  ],
  "license": "Apache-2.0",
  "homepage": "https://impeccable.style",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pbakaus/impeccable-flutter.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "impeccable-flutter": "cli/bin/cli.js"
  },
  "main": "./cli/engine/detect-antipatterns.mjs",
  "exports": {
    ".": "./cli/engine/detect-antipatterns.mjs"
  },
  "files": [
    "cli/",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "clean": "rm -rf dist build plugin/skills plugin/agents",
    "rebuild": "npm run clean && npm run build",
    "test": "node --test tests/impeccable-paths.test.mjs && node --test tests/cleanup-deprecated.test.mjs",
    "audit": "npm audit --audit-level=moderate",
    "prepack": "cp README.md README.repo.md && cp README.npm.md README.md",
    "postpack": "cp README.repo.md README.md && rm README.repo.md",
    "release:skill": "node scripts/release.mjs skill",
    "release:cli": "node scripts/release.mjs cli"
  },
  "dependencies": {
    "css-select": "^5.2.2",
    "css-tree": "^3.2.1",
    "domutils": "^3.2.2",
    "htmlparser2": "^10.0.0",
    "marked": "^16.4.2"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/genai": "^1.50.1",
    "ai": "^6.0.168",
    "archiver": "^7.0.1",
    "motion": "^12.38.0",
    "wrangler": "^4.85.0",
    "zod": "^4.3.6"
  }
}
